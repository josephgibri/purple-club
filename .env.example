# Solana RPC — optional. Falls back to public mainnet-beta cluster.
NEXT_PUBLIC_HELIUS_RPC_URL=
NEXT_PUBLIC_ALCHEMY_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# --- Merchant relay (v1) ---
# Classic PAT scoped only to the Purple Club repo, "repo" permission.
GITHUB_BOT_PAT=

# Repo that receives merchant issues + PRs, e.g. "purpleclub/purpleclub".
GITHUB_REPO=

# HMAC secret for signing merchant edit tokens. Generate 32+ random chars.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SIGNING_SECRET=

# Cloudflare Turnstile captcha on /join.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Origin used by scripts/generate-edit-token.ts when regenerating lost links.
# Defaults to https://purpleclub.xyz if unset.
PURPLE_CLUB_ORIGIN=

# --- Future: enabling email (v1.1) ---
# When magic-link recovery ships, uncomment RESEND_API_KEY and redeploy.
# No other env vars are needed to enable email — see README.
# RESEND_API_KEY=
